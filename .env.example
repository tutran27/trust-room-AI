# TrustRoom AI — environment template. Copy to .env and fill in. NEVER commit real values.

# --- App ---
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# --- Auth / session ---
JWT_SECRET=
SESSION_COOKIE_NAME=trustroom_session
AUTH_NONCE_TTL_SECONDS=300
AUTH_DOMAIN=localhost
AUTH_URI=http://localhost:3000
JWT_ISSUER=trustroom-ai
JWT_AUDIENCE=trustroom-api
CORS_ORIGINS=http://localhost:3000
JSON_BODY_LIMIT=32kb

# --- Database (PostgreSQL via Supabase) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustroom
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/trustroom

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=evidence

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Vector DB (Qdrant) + embeddings (bge-m3) ---
QDRANT_URL=http://localhost:6335
QDRANT_API_KEY=
EMBEDDINGS_MODEL=bge-m3
EMBEDDINGS_URL=

# --- LLM (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=

# --- Agora (RTC + STT + Conversational AI) ---
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
NEXT_PUBLIC_AGORA_APP_ID=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# --- Solana (devnet) ---
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
ESCROW_PROGRAM_ID=3DyccqgiVSUupDEfgvME8rduMHAgJdLxqhGEdPuhbjR7
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
ESCROW_SIGNER_KEY=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
