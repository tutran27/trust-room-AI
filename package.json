{
  "name": "trustroom-ai",
  "version": "0.0.0",
  "private": true,
  "description": "AI-supervised escrow room for high-risk P2P deals (Agora + Solana + Evidence Vault).",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @trustroom/web dev",
    "dev:api": "pnpm --filter @trustroom/api dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:push": "pnpm --filter @trustroom/db db:push",
    "db:seed": "pnpm --filter @trustroom/db seed",
    "demo:setup": "pnpm db:up && pnpm --filter @trustroom/db generate && pnpm db:push && pnpm db:seed",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "agora-extension-ai-denoiser": "^2.0.2",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0"
  }
}
